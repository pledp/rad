// DICOM UL state machine transition table.
// Each key is a source state. Inner keys are event names, values define the next state and commands to issue.
(
    transitions: {
        Sta1: {
            TransportConnectionIndication: (to: Sta2, commands: [StartArtimTimer]),
            AssociateRequestPrimitive: (to: Sta4, commands: [TransportConnectionRequest]),
        },
        Sta2: {
            AssociateRequestPdu:                (to: Sta3,  commands: [StopArtimTimer, AssociateIndicationPrimitive]),
            UnrecognizedPdu:                    (to: Sta13, commands: [AbortPdu, StartArtimTimer], reason: UnrecognizedPdu),
            UnexpectedPdu:                      (to: Sta13, commands: [AbortPdu, StartArtimTimer], reason: UnexpectedPdu),
            AssociateRejectPdu:                 (to: Sta13, commands: [AbortPdu, StartArtimTimer]),
            UnrecognizedPduParameter:           (to: Sta13, commands: [AbortPdu, StartArtimTimer], reason: UnrecognizedPduParameter),
            InvalidPduParameter:                (to: Sta13, commands: [AbortPdu, StartArtimTimer], reason: InvalidPduParameter),
            UnexpectedPduParameter:             (to: Sta13, commands: [AbortPdu, StartArtimTimer], reason: UnexpectedPduParameter),
            TransportConnectionClosedIndication:    (to: Sta1, commands: [StopArtimTimer]),
            ArtimTimerExpired:                  (to: Sta1,  commands: [CloseConnection]),
        },
        Sta3: {
            AcceptedAssociateResponsePrimitive:     (to: Sta6,  commands: [AssociateAcceptPdu]),
            RejectedAssociateResponsePrimitive:     (to: Sta13, commands: [AssociateRejectPdu, CloseConnection]),

            AssociateRejectPdu:                  (to: Sta13, commands: [AbortPdu, ProviderAbortIndicationPrimitive, StartArtimTimer]),
            UnrecognizedPdu:                    (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: UnrecognizedPdu),
            UnexpectedPdu:                      (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: UnexpectedPdu),
            UnrecognizedPduParameter:           (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: UnrecognizedPduParameter),
            InvalidPduParameter:                (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: InvalidPduParameter),
            UnexpectedPduParameter:             (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: UnexpectedPduParameter),
            TransportConnectionClosedIndication: (to: Sta1, commands: [ProviderAbortIndicationPrimitive]),
            AbortRequestPrimitive:              (to: Sta13, commands: [AbortPdu, StartArtimTimer]),
        },
        Sta4: {
            TransportConnectionConfirmation:    (to: Sta5,  commands: [AssociateRequestPdu]),
        },
        Sta5: {
            AssociateAcceptPdu:                 (to: Sta6,  commands: [AcceptedAssociateConfirmationPrimitive]),
            AssociateRejectPdu:                 (to: Sta1,  commands: [RejectedAssociateConfirmationPrimitive]),

            UnrecognizedPdu:                    (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: UnrecognizedPdu),
            UnexpectedPdu:                      (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: UnexpectedPdu),
            AbortRequestPrimitive:              (to: Sta13, commands: [AbortPdu, StartArtimTimer]),
            TransportConnectionClosedIndication: (to: Sta1, commands: [ProviderAbortIndicationPrimitive]),
            UnrecognizedPduParameter:           (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: UnrecognizedPduParameter),
            InvalidPduParameter:                (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: InvalidPduParameter),
            UnexpectedPduParameter:             (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: UnexpectedPduParameter),
        },
        Sta6: {
            AssociateRejectPdu:                 (to: Sta1,  commands: [AbortPdu, ProviderAbortIndicationPrimitive, StartArtimTimer]),
            UnrecognizedPdu:                    (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: UnrecognizedPdu),
            UnexpectedPdu:                      (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: UnexpectedPdu),
            UnrecognizedPduParameter:           (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: UnrecognizedPduParameter),
            InvalidPduParameter:                (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: InvalidPduParameter),
            UnexpectedPduParameter:             (to: Sta13, commands: [AbortPdu, StartArtimTimer, ProviderAbortIndicationPrimitive], reason: UnexpectedPduParameter),
            TransportConnectionClosedIndication: (to: Sta1, commands: [ProviderAbortIndicationPrimitive]),
            AbortRequestPrimitive:              (to: Sta13, commands: [AbortPdu, StartArtimTimer]),
        },
        Sta13: {
            UnrecognizedPdu:                    (to: Sta13, commands: [AbortPdu], reason: UnrecognizedPdu),
            UnexpectedPdu:                      (to: Sta13, commands: [AbortPdu], reason: UnexpectedPdu),
            UnrecognizedPduParameter:           (to: Sta13, commands: [AbortPdu], reason: UnrecognizedPduParameter),
            InvalidPduParameter:                (to: Sta13, commands: [AbortPdu], reason: InvalidPduParameter),
            UnexpectedPduParameter:             (to: Sta13, commands: [AbortPdu], reason: UnexpectedPduParameter),
            TransportConnectionClosedIndication: (to: Sta1, commands: [StopArtimTimer]),
            ArtimTimerExpired:                  (to: Sta1,  commands: [CloseConnection]),
        },
    }
)
